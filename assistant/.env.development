# Development-only local state. Source this from the repository root:
# set -a; source .env.development; set +a

ASSISTANT_HOME=.local/assistant
ASSISTANT_NOTES_DIR=.local/notes
ASSISTANT_DB_PATH=.local/assistant/assistant.db
ASSISTANT_REGISTRY_PATH=tools/registry.yaml
ASSISTANT_DEBUG_LOG_PATH=.local/assistant/debug.log
ASSISTANT_LLM_SUMMARY_PATH=.local/assistant/last-llm-request.md
ASSISTANT_RESEARCH_DIR=.local/notes/research

ASSISTANT_LLAMA_MODEL_PATH=
ASSISTANT_LLAMA_CONTEXT_SIZE=4096
ASSISTANT_LLAMA_MAX_TOKENS=256
ASSISTANT_LLAMA_TEMPERATURE=0.2

ASSISTANT_REMOTE_PROVIDER=openai-compatible
ASSISTANT_REMOTE_MODEL=gpt-4.1-mini
ASSISTANT_REMOTE_API_KEY=
ASSISTANT_REMOTE_BASE_URL=https://api.openai.com/v1
ASSISTANT_REMOTE_TIMEOUT=30
